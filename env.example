# 🗄️ Variables de Base de Datos
# Configuración para conexión a PostgreSQL

# Host de la base de datos (producción o local)
DB_HOST=tu_host_de_produccion

# Usuario de la base de datos
DB_USER=tu_usuario

# Nombre de la base de datos
DB_DATABASE=tu_database

# Contraseña de la base de datos
DB_PASSWORD=tu_password

# Puerto de la base de datos (opcional, por defecto 5432)
DB_PORT=5432

# 🔧 Otras variables de entorno del proyecto
DEBUG=True
ENV=local
APP_URL=http://localhost:8000

# 🔐 Autenticación Google OAuth2
GOOGLE_CLIENT_ID=tu_google_client_id
GOOGLE_CLIENT_SECRET=tu_google_client_secret

# 📅 Google Calendar API para Espacio Zen (Service Account)
# Extrae estos valores del JSON key que descargaste de Google Cloud Console:
# 1. client_email -> ESPACIO_ZEN_CLIENT_EMAIL
# 2. private_key -> ESPACIO_ZEN_PRIVATE_KEY (mantén los \n como están en el JSON)
ESPACIO_ZEN_CLIENT_EMAIL=tu-service-account@project-id.iam.gserviceaccount.com
ESPACIO_ZEN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# 💳 MercadoPago
MERCADOPAGO_PUBLIC_KEY=tu_mercadopago_public_key
MERCADOPAGO_ACCESS_TOKEN=tu_mercadopago_access_token
MERCADOPAGO_WEBHOOK_SECRET=tu_mercadopago_webhook_secret
# ID numérico del usuario cobrador (caja v2 — MercadoPago Instore QR/Postnet)
MERCADOPAGO_COLLECTOR_USER_ID=tu_collector_user_id

# Planes de suscripción de La Sede (IDs separados por coma)
SUBS_IDS=plan_id_1,plan_id_2

# 📧 Configuración de Email (para testing con Mailtrap)
EMAIL_HOST=tu_email_host
EMAIL_PORT=tu_email_port
EMAIL_HOST_USER=tu_email_user
EMAIL_HOST_PASSWORD=tu_email_password
EMAIL_USE_TLS=True

# 🔑 Django Secret Key (generar uno nuevo para producción)
SECRET_KEY=tu_django_secret_key

# 🌐 Hosts permitidos (separados por comas)
ALLOWED_HOSTS=localhost,127.0.0.1,tu_dominio.com

# 📁 Configuración de archivos estáticos
STATIC_URL=/static/
MEDIA_URL=/media/

# 🗄️ Configuración adicional de base de datos
# Para usar un schema específico en PostgreSQL
# DB_OPTIONS=-c search_path=ticketera_new,public
